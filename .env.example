LITELLM_MASTER_KEY=sk-your-master-key
CLAUDE_OAUTH_TOKEN=sk-ant-oat01-your-claude-oauth-token

# --- vllm-qwen35 (optional overrides; defaults work for the standard build) ---
MODELS_DIR=./models                                  # host dir mounted to /models
QWEN_MODEL_PATH=/models/qwen35-122b-hybrid-int4fp8   # served checkpoint path

# --- hermes (optional overrides; defaults work) -------------------------------
HERMES_IMAGE=nousresearch/hermes-agent:latest        # gateway image
HERMES_UID=10000                                      # owner uid for /opt/data
HERMES_GID=10000                                      # owner gid for /opt/data

# Hermes dashboard (web UI) admin auth. The dashboard exposes config / API keys /
# sessions, so it is served with HTTP Basic auth. REPLACE these placeholders with
# a real password and a long random secret before using it.
HERMES_DASHBOARD_BASIC_AUTH_USERNAME=admin
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=change-me-please
HERMES_DASHBOARD_BASIC_AUTH_SECRET=change-me-to-a-long-random-string

# Hermes messaging-platform creds, injected into the container as env vars (see
# docker-compose.yml). Leave a platform's vars blank if it is disabled in
# hermes/config.yaml. Each platform is toggled there under platforms.*.enabled.

# Discord (platforms.discord.enabled). ALLOWED_USERS / HOME_CHANNEL are IDs.
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_ALLOWED_USERS=your-discord-user-id
DISCORD_HOME_CHANNEL=your-home-channel-id

# LINE (platforms.line.enabled). PUBLIC_URL is the webhook base URL.
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_PUBLIC_URL=https://your-hermes-gateway.example.com
LINE_ALLOW_ALL_USERS=true
